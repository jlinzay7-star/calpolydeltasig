# Copy this file to `.env` and fill in the real values from the Supabase dashboard.
# The real .env is gitignored — never commit secrets.

# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOURPROJECT.supabase.co

# service_role key — secret! Only used by the local seed script.
# DO NOT put this in Netlify env vars, do NOT expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME...

# JWT secret — any random 32+ char string. Must match the one you set in Supabase Edge Functions.
# Generate with:  openssl rand -base64 48
JWT_SECRET=replace_me_with_at_least_32_characters_of_random_stuff
